# .gitignore

# Cargo & Rust
/target/
**/*.rs.bk

# Node & JS
node_modules/
dist/
.env

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# MacOS & Windows
.DS_Store
Thumbs.db

# Developer specific
.vscode/
.idea/

# Synod specific
.synod-os/
logs/
.gemini/
.agents/
__synod_doc_extract.txt
*.docx

# Security
*.pem
*.key
!config/default.toml
!tests/fixtures/

# Local analysis notes
LOCAL_ARCHITECTURE_REVIEW.md

# Local tooling and generated artifacts
.kiro/
synod-coordinator/check_errors.txt
synod-coordinator/check_errors_utf8.txt
synod-coordinator/generator_output.txt
synod-coordinator/tmp/
